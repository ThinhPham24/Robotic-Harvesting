{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DENSO RC7M Telemetry v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "sequence",
    "source_time_unix_ns",
    "controller",
    "robot",
    "joint_names",
    "joint_position_deg",
    "mode",
    "servo_on",
    "emergency_stop",
    "alarm_code"
  ],
  "properties": {
    "protocol": {"const": "denso_rc7m.telemetry.v1"},
    "sequence": {"type": "integer", "minimum": 0},
    "source_time_unix_ns": {"type": "integer", "minimum": 0},
    "controller": {"type": "string", "maxLength": 32},
    "robot": {"type": "string", "maxLength": 32},
    "joint_names": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {"type": "string", "maxLength": 32}
    },
    "joint_position_deg": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {"type": "number", "minimum": -720, "maximum": 720}
    },
    "joint_velocity_deg_s": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {"type": "number", "minimum": -2000, "maximum": 2000}
    },
    "mode": {"enum": ["UNKNOWN", "MANUAL", "TEACH", "AUTO", "REMOTE"]},
    "servo_on": {"type": "boolean"},
    "emergency_stop": {"type": "boolean"},
    "protective_stop": {"type": "boolean"},
    "alarm_code": {"type": "integer"},
    "alarm_text": {"type": "string", "maxLength": 256},
    "native_task": {"type": "string", "maxLength": 64},
    "cycle_count": {"type": "integer", "minimum": 0}
  }
}
